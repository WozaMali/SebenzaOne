{
  "name": "sebenza-waste-suite",
  "version": "1.0.0",
  "description": "Sebenza Waste - Complete business suite with landing page and office applications",
  "private": true,
  "workspaces": [
    "landing-site",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:landing\" \"npm run dev:accounts\" \"npm run dev:crm\" \"npm run dev:projects\"",
    "dev:landing": "cd landing-site && npm run dev",
    "dev:accounts": "cd apps/accounts-app && npm run dev",
    "dev:crm": "cd apps/crm-app && npm run dev",
    "dev:projects": "cd apps/projects-app && npm run dev",
    "build": "npm run build:landing",
    "build:landing": "cd landing-site && npm run build",
    "start": "npm run start:all",
    "start:all": "concurrently \"npm run start:landing\"",
    "start:landing": "cd landing-site && npm run start",
    "install:all": "npm install && cd landing-site && npm install",
    "clean": "npm run clean:landing",
    "clean:landing": "cd landing-site && rm -rf dist node_modules",
    "lint": "npm run lint:landing",
    "lint:landing": "cd landing-site && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WozaMali/SebenzaOne.git"
  },
  "keywords": [
    "sebenza",
    "waste-management",
    "office-suite",
    "landing-page",
    "react",
    "nextjs",
    "vite",
    "typescript"
  ],
  "author": "Sebenza Waste Team",
  "license": "MIT",
  "dependencies": {
    "react-to-print": "^3.2.0"
  }
}
